// LeetCode 36: Valid Sudoku
// One pass using hash sets for row/column/box constraints.

fn is_valid_sudoku(board: list) -> bool {
    seen: hash = {};
    r: int = 0;

    while r < 9 {
        c: int = 0;
        while c < 9 {
            ch: str = board[r][c];

            if ch != "." {
                box: int = ((r / 3) * 3) + (c / 3);
                row_key: str = "r" + r.asString() + ":" + ch;
                col_key: str = "c" + c.asString() + ":" + ch;
                box_key: str = "b" + box.asString() + ":" + ch;

                if seen.ensure(row_key, false) || seen.ensure(col_key, false) || seen.ensure(box_key, false) {
                    return false;
                }

                seen[row_key] = true;
                seen[col_key] = true;
                seen[box_key] = true;
            }

            c = c + 1;
        }

        r = r + 1;
    }

    return true;
}

board1: list = [
    ["5", "3", ".", ".", "7", ".", ".", ".", "."],
    ["6", ".", ".", "1", "9", "5", ".", ".", "."],
    [".", "9", "8", ".", ".", ".", ".", "6", "."],
    ["8", ".", ".", ".", "6", ".", ".", ".", "3"],
    ["4", ".", ".", "8", ".", "3", ".", ".", "1"],
    ["7", ".", ".", ".", "2", ".", ".", ".", "6"],
    [".", "6", ".", ".", ".", ".", "2", "8", "."],
    [".", ".", ".", "4", "1", "9", ".", ".", "5"],
    [".", ".", ".", ".", "8", ".", ".", "7", "9"]
];

board2: list = [
    ["8", "3", ".", ".", "7", ".", ".", ".", "."],
    ["6", ".", ".", "1", "9", "5", ".", ".", "."],
    [".", "9", "8", ".", ".", ".", ".", "6", "."],
    ["8", ".", ".", ".", "6", ".", ".", ".", "3"],
    ["4", ".", ".", "8", ".", "3", ".", ".", "1"],
    ["7", ".", ".", ".", "2", ".", ".", ".", "6"],
    [".", "6", ".", ".", ".", ".", "2", "8", "."],
    [".", ".", ".", "4", "1", "9", ".", ".", "5"],
    [".", ".", ".", ".", "8", ".", ".", "7", "9"]
];

say(is_valid_sudoku(board1));
say(is_valid_sudoku(board2));
